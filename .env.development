# Local development overrides for backend microservices
DOCS_SERVICE_URL=http://127.0.0.1:8084
ACCOUNT_SERVICE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_ACCOUNT_SERVICE_URL=http://127.0.0.1:8080
SERVER_SERVICE_URL=http://127.0.0.1:8082
NEXT_PUBLIC_SERVER_SERVICE_URL=http://127.0.0.1:8082

# Force local insecure cookies to simplify testing auth locally
SESSION_COOKIE_SECURE=false
NEXT_PUBLIC_SESSION_COOKIE_SECURE=false

# Override environment identity
RUNTIME_ENV=dev
NEXT_PUBLIC_RUNTIME_ENVIRONMENT=dev
